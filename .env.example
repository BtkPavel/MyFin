# PostgreSQL (обязательно для Vercel)
# Локально: Homebrew postgres (createdb myfin), Neon, Supabase или Docker
# Vercel: создать БД в Vercel Storage → Postgres или подключить Neon/Supabase
# Локальный Homebrew: postgresql://mac@localhost:5432/myfin?schema=public
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
